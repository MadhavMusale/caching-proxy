# ─────────────────────────────────────────────────────────────
# CacheProxy — Environment Variables
# cp .env.example .env  →  fill in values  →  never commit .env
# ─────────────────────────────────────────────────────────────

# ── Admin API Key (seeded on first boot if DB is empty) ──
# Leave blank to auto-generate (key printed to logs once)
ADMIN_API_KEY=

# ── Proxy Settings ──────────────────────────────────────────
PROXY_ORIGIN=http://dummyjson.com
PROXY_TIMEOUT=30
ALLOWED_ORIGINS=*
CACHE_TTL_HOURS=1

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_RPM=100
RATE_LIMIT_BURST=20

# ── PostgreSQL ───────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=proxydb
DB_USER=proxy
DB_PASSWORD=change-me-strong-password

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password

# ── Frontend ─────────────────────────────────────────────────
# Your production domain (used to build the React app)
VITE_API_URL=https://YOUR_DOMAIN
